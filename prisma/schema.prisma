generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── AUTH (next-auth) ────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USUÁRIOS ────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("operador")
  active    Boolean  @default(true)
  storeId   String?
  createdAt DateTime @default(now())

  store          Store?          @relation(fields: [storeId], references: [id])
  accounts       Account[]
  sessions       Session[]
  sales          Sale[]
  expenses       Expense[]
  stockMovements StockMovement[]
  cashSessions   CashSession[]
  cashMovements  CashMovement[]
  comandas       Comanda[]
  aiChats        AiChat[]
}

// ─── LOJA ────────────────────────────────────────────────────
model Store {
  id            String   @id @default(cuid())
  name          String
  cnpj          String?
  phone         String?
  address       String?
  logoUrl       String?
  cmvTarget     Float    @default(30)
  defaultMarkup Float    @default(70)
  taxRate       Float    @default(0)
  currency      String   @default("BRL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users       User[]
  categories  Category[]
  ingredients Ingredient[]
  products    Product[]
  sales        Sale[]
  expenses     Expense[]
  customers    Customer[]
  cashSessions CashSession[]
  comandas     Comanda[]
  aiConfig     AiConfig?
  aiChats      AiChat[]
}

// ─── CATEGORIAS ───────────────────────────────────────────────
model Category {
  id       String    @id @default(cuid())
  name     String
  color    String    @default("#f97316")
  storeId  String
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]
}

// ─── INSUMOS / ESTOQUE ────────────────────────────────────────
model Ingredient {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  unit        String   @default("kg")
  stockQty    Float    @default(0)
  minStock    Float    @default(0)
  costPerUnit Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockMovements     StockMovement[]
  productIngredients ProductIngredient[]
}

// ─── MOVIMENTAÇÕES DE ESTOQUE ─────────────────────────────────
model StockMovement {
  id           String   @id @default(cuid())
  ingredientId String
  userId       String
  type         String   // entrada | saida_venda | saida_producao | saida_perda | ajuste
  qty          Float
  unitCost     Float    @default(0)
  referenceId  String?
  note         String?
  createdAt    DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
}

// ─── PRODUTOS ─────────────────────────────────────────────────
model Product {
  id            String   @id @default(cuid())
  storeId       String
  categoryId    String?
  name          String
  internalCode  String?
  unit          String   @default("un")
  tipo          String   @default("fabricacao") // revenda | fabricacao
  purchasePrice Float    @default(0)            // custo de compra (revenda)
  salePrice     Float    @default(0)
  imageUrl      String?
  tipoProducao  String   @default("unitario")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id])
  productIngredients ProductIngredient[]
  saleItems          SaleItem[]
  comandaItems       ComandaItem[]

  @@unique([storeId, internalCode])
}

// ─── FICHA TÉCNICA ────────────────────────────────────────────
model ProductIngredient {
  id           String @id @default(cuid())
  productId    String
  ingredientId String
  qtyPerUnit   Float

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([productId, ingredientId])
}

// ─── CLIENTES ────────────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  phone     String?
  birthdate String?
  notes     String?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sales    Sale[]
  comandas Comanda[]
}

// ─── VENDAS ──────────────────────────────────────────────────
model Sale {
  id            String   @id @default(cuid())
  storeId       String
  userId        String
  customerId    String?
  cashSessionId String?
  totalAmount   Float    @default(0)
  totalCost     Float    @default(0)
  cmvPct        Float    @default(0)
  discount      Float    @default(0)
  paymentMethod String   @default("dinheiro")
  status        String   @default("concluida")
  notes         String?
  createdAt     DateTime @default(now())

  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  items       SaleItem[]
}

// ─── ITENS DA VENDA ───────────────────────────────────────────
model SaleItem {
  id        String @id @default(cuid())
  saleId    String
  productId String
  qty       Float
  unitPrice Float
  unitCost  Float  @default(0)
  subtotal  Float
  costTotal Float  @default(0)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── CAIXA (FECHAMENTO CEGO) ──────────────────────────────────
model CashSession {
  id            String    @id @default(cuid())
  storeId       String
  userId        String
  openingAmount Float     @default(0) // fundo de troco
  status        String    @default("aberta") // aberta | fechada
  countedCash   Float? // valores contados no fechamento cego
  countedPix    Float?
  countedDebit  Float?
  countedCredit Float?
  notes         String?
  openedAt      DateTime  @default(now())
  closedAt      DateTime?

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])
  movements CashMovement[]
  sales     Sale[]
}

model CashMovement {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  type      String // sangria | suprimento
  amount    Float
  reason    String?
  createdAt DateTime @default(now())

  session CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])
}

// ─── COMANDAS ─────────────────────────────────────────────────
model Comanda {
  id         String    @id @default(cuid())
  storeId    String
  userId     String
  customerId String?
  label      String // identificação: nome, mesa, etc.
  status     String    @default("aberta") // aberta | finalizada | cancelada
  notes      String?
  createdAt  DateTime  @default(now())
  closedAt   DateTime?

  store    Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  items    ComandaItem[]
}

model ComandaItem {
  id        String @id @default(cuid())
  comandaId String
  productId String
  qty       Float
  unitPrice Float

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── DESPESAS ────────────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  storeId     String
  userId      String
  category    String
  description String
  amount      Float
  date        String
  recurrent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

// ─── CONFIGURAÇÃO DE IA ───────────────────────────────────────
model AiConfig {
  id          String   @id @default(cuid())
  storeId     String   @unique
  provider    String   @default("google")
  model       String   @default("gemini-2.0-flash")
  apiKey      String?
  ollamaUrl   String   @default("http://localhost:11434")
  temperature Float    @default(0.7)
  maxTokens   Int      @default(1024)
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ─── HISTÓRICO CHAT IA ────────────────────────────────────────
model AiChat {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  message   String
  response  String
  provider  String   @default("google")
  model     String   @default("gemini-2.0-flash")
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}
